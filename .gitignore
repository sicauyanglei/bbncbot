# Gradle
.gradle/
build/

# Local configuration file (sdk path, etc)
local.properties

# Sign files（release.keystore 已固定提交到仓库，保证每次 CI 签名一致）
*.jks
debug.keystore

# IDE
.idea/
*.iml
.vscode/
.trae/
# 例外：项目规则文件需要提交到版本库，让远端会话也能加载规则
!.trae/rules/

# OS
.DS_Store
Thumbs.db

# Logs
*.log
# App 运行时上传的调试日志目录（LogUploader 通过 GitHub Contents API 上传，
# 不应进入版本库，否则每次上传日志都会产生 commit 污染历史）
logs/

# APK & build outputs
*.apk
*.aab
*.ap_
*.dex

# Native build
.cxx/

# Python cache
__pycache__/
*.pyc

# Screenshots & debug dumps
*.png
*.jpg
*.jpeg
*.txt

# Debug scripts
*.py
dump*
acs*
/act*
top*
cur*
/activity*
