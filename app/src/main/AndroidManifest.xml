<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 悬浮窗权限 -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <!-- 前台 Service 保活 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <!-- 通知权限（Android 13+） -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- 查询 UC 极速版（Android 11+ 包可见性） -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />
    <!-- 获取前台任务（用于检测 UC 是否在前台） -->
    <uses-permission android:name="android.permission.GET_TASKS" />
    <!-- 网络权限（WebView 加载农场页面） -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- 强杀广告深链跳转拉起的 App（21秒超时后 killBackgroundProcesses） -->
    <uses-permission android:name="android.permission.KILL_BACKGROUND_PROCESSES" />
    <!-- 枚举桌面快捷方式（需要本 App 被设为默认桌面） -->
    <uses-permission android:name="android.permission.GET_SHORTCUTS" />

    <!--
        OCR 跨进程调用：ContentProvider call() 方案
        - OCR APK 提供 OcrContentProvider（authorities=com.bbncbot.ocr.provider）
        - 主 APK 通过 ContentResolver.call() 调用，不走 bindService
        - 不用 signature 权限：之前 provider 声明 android:permission 导致
          系统查找 provider 时预检查权限，权限未授予时 provider 被过滤
          → Unknown authority（与 bindService 的权限陷阱同理）
        - 安全由 OcrContentProvider.call() 内部包名白名单保证
    -->

    <!-- 查询 OCR APK 是否已安装（Android 11+ 包可见性） -->
    <queries>
        <package android:name="com.bbncbot.ocr" />
    </queries>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/backup_rules"
        android:fullBackupContent="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.BBNCFarmBot"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- 注册为桌面（CATEGORY_HOME），使本 App 可被设为默认桌面以获得 GET_SHORTCUTS 权限 -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
            </intent-filter>
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity>

        <!-- 芭芭农场 WebView 页面 -->
        <activity
            android:name=".FarmWebActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:launchMode="singleTask" />

        <!-- 场景规则查看与编辑界面 -->
        <activity
            android:name=".RuleEditorActivity"
            android:exported="false"
            android:label="场景规则编辑"
            android:parentActivityName=".MainActivity" />

        <!-- 慢放回放中的规则编辑界面（对话框风格，从悬浮窗✎按钮启动） -->
        <activity
            android:name=".SlowReplayEditActivity"
            android:exported="false"
            android:theme="@style/Theme.MaterialComponents.Light.Dialog"
            android:label="编辑当前规则" />

        <!-- 悬浮窗前台 Service -->
        <service
            android:name=".service.FloatingWindowService"
            android:exported="true"
            android:foregroundServiceType="specialUse">
            <intent-filter>
                <action android:name="com.bbncbot.START_AUTOMATION" />
                <action android:name="com.bbncbot.STOP_AUTOMATION" />
                <action android:name="com.bbncbot.DUMP_NODES" />
                <action android:name="com.bbncbot.TOGGLE_INTERACTIVE" />
                <action android:name="com.bbncbot.OPEN_TEACH" />
                <action android:name="com.bbncbot.TOGGLE_RECORDING" />
                <action android:name="com.bbncbot.INTERRUPT" />
                <action android:name="com.bbncbot.DUMP_RULES" />
                <action android:name="com.bbncbot.START_SLOW_REPLAY" />
                <action android:name="com.bbncbot.STOP_SLOW_REPLAY" />
            </intent-filter>
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="用户主动启动的农场自动化辅助悬浮窗，需要持续显示控制按钮" />
        </service>

        <!-- 无障碍服务 -->
        <service
            android:name=".service.FarmAccessibilityService"
            android:exported="true"
            android:label="@string/accessibility_service_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

    </application>

</manifest>
