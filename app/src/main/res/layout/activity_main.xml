<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 状态显示 -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:text="状态：未启动"
            android:textSize="14sp"
            android:background="#F5F5F5" />

        <!-- 权限按钮 -->
        <Button
            android:id="@+id/btnOpenAccessibility"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="开启无障碍服务" />

        <Button
            android:id="@+id/btnRequestOverlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="悬浮窗权限" />

        <Button
            android:id="@+id/btnStartFloating"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="启动悬浮窗" />

        <!-- 打开农场 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="打开农场"
            android:textStyle="bold"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btnOpenFarm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="UC 芭芭农场" />

        <Button
            android:id="@+id/btnOpenAlipayFarm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="支付宝芭芭农场" />

        <Button
            android:id="@+id/btnOpenTaobaoFarm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="淘宝芭芭农场" />

        <!-- 日志上传配置 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="日志上传"
            android:textStyle="bold"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="12sp"
            android:textColor="#888888"
            android:text="点击下方按钮可手动上传 debug.log / proposals.log / teachings.log + 截图到 GitHub 仓库 logs/ 目录，便于远程查看运行日志。Token 仅本地存储。建议用 fine-grained PAT 仅授权本仓库 contents:write。" />

        <EditText
            android:id="@+id/etGhToken"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="GitHub Personal Access Token"
            android:inputType="textPassword" />

        <Button
            android:id="@+id/btnSaveGhToken"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="保存 GitHub Token" />

        <TextView
            android:id="@+id/tvGhTokenStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="12sp"
            android:textColor="#888888" />

        <Button
            android:id="@+id/btnTestUpload"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="立即测试上传日志" />

        <TextView
            android:id="@+id/tvUploadResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="12sp"
            android:textColor="#888888"
            android:text="点上面按钮立即上传当前日志，验证 Token 是否有效" />

    </LinearLayout>
</ScrollView>
