<?xml version="1.0" encoding="utf-8"?>
<!--
    场景归类确认浮窗
    - 录制时遇到未归类的 signature 弹出
    - 用户输入场景名 → 创建新场景分类
    - 或从列表选已有分类 → 归到该分类
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:minWidth="320dp"
    android:maxHeight="500dp"
    android:background="#EE1F1F1F"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp"
    android:elevation="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="场景归类确认"
            android:textColor="#FFD700"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCatActionDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="动作：滑动 UP"
            android:textColor="#4CAF50"
            android:textSize="12sp"
            tools:ignore="HardcodedText" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="场景特征签名："
            android:textColor="#CCCCCC"
            android:textSize="11sp"
            tools:ignore="HardcodedText" />

        <TextView
            android:id="@+id/tvCatSignature"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:background="#33FFFFFF"
            android:padding="4dp"
            android:text="p=UC|farm=false|..."
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            tools:ignore="HardcodedText" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="页面文本（前 5 项）："
            android:textColor="#CCCCCC"
            android:textSize="11sp"
            tools:ignore="HardcodedText" />

        <TextView
            android:id="@+id/tvCatPageTexts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:background="#33FFFFFF"
            android:padding="4dp"
            android:text="[文本1, 文本2, ...]"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            tools:ignore="HardcodedText" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="1) 创建新场景（输入名称）："
            android:textColor="#CCCCCC"
            android:textSize="11sp"
            tools:ignore="HardcodedText" />

        <EditText
            android:id="@+id/etCategoryName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="#33FFFFFF"
            android:hint="如：浏览15秒任务"
            android:inputType="text"
            android:maxLines="1"
            android:padding="8dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#AAAAAA"
            android:textSize="12sp"
            tools:ignore="HardcodedText" />

        <Button
            android:id="@+id/btnCreateCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:minHeight="40dp"
            android:text="创建新场景"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:background="@drawable/bg_floating_button"
            tools:ignore="HardcodedText" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="2) 或归到已有场景："
            android:textColor="#CCCCCC"
            android:textSize="11sp"
            tools:ignore="HardcodedText" />

        <LinearLayout
            android:id="@+id/llExistingCategories"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="vertical" />

        <Button
            android:id="@+id/btnCatCancel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:minHeight="36dp"
            android:text="取消（不记录）"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:background="@drawable/bg_floating_button"
            tools:ignore="HardcodedText" />

    </LinearLayout>
</ScrollView>
