<?xml version="1.0" encoding="utf-8"?>
<!--
    动作询问浮窗布局
    - 当 ActionProposer.enabled=true 且有待响应提议时显示
    - 用户点 同意/拒绝/跳过 后浮窗消失，状态机继续执行
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:minWidth="280dp"
    android:orientation="vertical"
    android:background="#EE1F1F1F"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp"
    android:elevation="6dp">

    <TextView
        android:id="@+id/tvProposalTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="拟执行动作"
        android:textColor="#FFD700"
        android:textSize="13sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvProposalAction"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        tools:ignore="HardcodedText" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="原因"
        android:textColor="#FFD700"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/tvProposalReason"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="#CCCCCC"
        android:textSize="12sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="页面摘要"
        android:textColor="#FFD700"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/tvProposalPage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:maxLines="3"
        android:ellipsize="end"
        android:textColor="#999999"
        android:textSize="11sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnApprove"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minHeight="40dp"
            android:text="同意"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:background="@drawable/bg_floating_button"
            tools:ignore="HardcodedText" />

        <Space
            android:layout_width="8dp"
            android:layout_height="wrap_content" />

        <Button
            android:id="@+id/btnReject"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minHeight="40dp"
            android:text="拒绝"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:background="@drawable/bg_floating_button_red"
            tools:ignore="HardcodedText" />

        <Space
            android:layout_width="8dp"
            android:layout_height="wrap_content" />

        <Button
            android:id="@+id/btnSkip"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minHeight="40dp"
            android:text="跳过"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:background="@drawable/bg_floating_button"
            tools:ignore="HardcodedText" />
    </LinearLayout>

</LinearLayout>
