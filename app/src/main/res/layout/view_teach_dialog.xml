<?xml version="1.0" encoding="utf-8"?>
<!--
    录制控制浮窗布局
    - 录制开关：开启/停止录制
    - 中断按钮：立即停止 bot 当前动作 + 删除当前场景规则
    - 状态显示：当前录制规则数
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:minWidth="280dp"
    android:orientation="vertical"
    android:background="#EE1F1F1F"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp"
    android:elevation="6dp">

    <TextView
        android:id="@+id/tvRecordingTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="录制控制"
        android:textColor="#FFD700"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvRecordingStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="录制未开启"
        android:textColor="#CCCCCC"
        android:textSize="12sp"
        tools:ignore="HardcodedText" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnRecordToggle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minHeight="44dp"
            android:text="开始录制"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="@drawable/bg_floating_button"
            tools:ignore="HardcodedText" />

        <Space
            android:layout_width="8dp"
            android:layout_height="wrap_content" />

        <Button
            android:id="@+id/btnInterrupt"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minHeight="44dp"
            android:text="中断"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="@drawable/bg_floating_button_red"
            tools:ignore="HardcodedText" />
    </LinearLayout>

    <Button
        android:id="@+id/btnClosePanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:minHeight="36dp"
        android:text="关闭"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:background="@drawable/bg_floating_button"
        tools:ignore="HardcodedText" />

</LinearLayout>
