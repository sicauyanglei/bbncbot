<?xml version="1.0" encoding="utf-8"?>
<!--
    教学浮窗布局
    - 用户主动下发指令：可输入自然语言（如"点 立即领取"、"滑动"、"返回"）或点快捷按钮
    - 指令记录到 teachings.log 作为规则样本
    - 简单关键词解析后执行
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:minWidth="300dp"
    android:orientation="vertical"
    android:background="#EE1F1F1F"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp"
    android:elevation="6dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="教我做什么"
        android:textColor="#4CAF50"
        android:textSize="14sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/etTeachInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:hint="如：点 立即领取 / 滑动 / 返回 / 等待 5秒 / 退出"
        android:hintTextColor="#888888"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:inputType="text"
        android:imeOptions="actionDone"
        android:background="@android:color/transparent"
        android:padding="8dp"
        tools:ignore="Autofill,HardcodedText" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#444444" />

    <!-- 快捷按钮区：常用动作一键执行 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnQuickSwipeUp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minHeight="36dp"
            android:text="↑滑"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:background="@drawable/bg_floating_button"
            tools:ignore="HardcodedText" />

        <Space android:layout_width="6dp" android:layout_height="wrap_content" />

        <Button
            android:id="@+id/btnQuickSwipeDown"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minHeight="36dp"
            android:text="↓滑"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:background="@drawable/bg_floating_button"
            tools:ignore="HardcodedText" />

        <Space android:layout_width="6dp" android:layout_height="wrap_content" />

        <Button
            android:id="@+id/btnQuickBack"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minHeight="36dp"
            android:text="返回"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:background="@drawable/bg_floating_button"
            tools:ignore="HardcodedText" />

        <Space android:layout_width="6dp" android:layout_height="wrap_content" />

        <Button
            android:id="@+id/btnQuickExit"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minHeight="36dp"
            android:text="退出"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:background="@drawable/bg_floating_button_red"
            tools:ignore="HardcodedText" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnTeachExecute"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minHeight="40dp"
            android:text="执行指令"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="@drawable/bg_floating_button"
            tools:ignore="HardcodedText" />

        <Space android:layout_width="8dp" android:layout_height="wrap_content" />

        <Button
            android:id="@+id/btnTeachClose"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:minHeight="40dp"
            android:text="关闭"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:background="@drawable/bg_floating_button_red"
            tools:ignore="HardcodedText" />
    </LinearLayout>

</LinearLayout>
