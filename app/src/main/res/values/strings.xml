<resources>
    <string name="app_name">芭芭农场机器人</string>

    <!-- 主界面 -->
    <string name="usage_guide">使用步骤：\n1. 授予悬浮窗权限\n2. 开启无障碍服务\n3. 点击"启动悬浮窗"\n4. 点击下方任一平台按钮打开农场（UC/支付宝/淘宝）\n5. 在农场页面点击悬浮窗"开始施肥"按钮（无障碍服务自动识别平台）</string>
    <string name="btn_request_overlay">授予悬浮窗权限</string>
    <string name="btn_open_accessibility">开启无障碍服务</string>
    <string name="btn_start_floating">启动悬浮窗</string>
