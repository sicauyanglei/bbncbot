<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
        signature 级权限保护 ContentProvider
        - ContentProvider 的 android:permission 对 call() 也生效
        - signature 级：只授予同签名 APK，第三方无法调用
        - 注意：ContentProvider 权限不依赖"先定义后授予"机制
          （不同于 Service 的 bindService 权限，Provider 权限在 query/call 时即时检查）
    -->
    <permission
        android:name="com.bbncbot.ocr.permission.BIND_OCR"
        android:protectionLevel="signature" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MaterialComponents.DayNight"
        tools:targetApi="34">

        <!-- 启动页：仅展示"OCR 模块已安装"，无实际交互 -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            OCR ContentProvider
            - authorities: com.bbncbot.ocr.provider
            - exported=true：允许主 APK 跨进程调用
            - android:permission：signature 级权限保护（同签名才可调用）
            - 注意：不再需要 OcrService，删除 <service> 声明
        -->
        <provider
            android:name=".OcrContentProvider"
            android:authorities="com.bbncbot.ocr.provider"
            android:exported="true"
            android:permission="com.bbncbot.ocr.permission.BIND_OCR" />

    </application>

</manifest>
