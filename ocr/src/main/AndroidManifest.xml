<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
        自定义 signature 级权限：只有与 :ocr 同签名的 APK（即 :app）才能绑定此 Service
        protectionLevel="signature" 保证第三方应用无法调用 OCR 能力
    -->
    <permission
        android:name="com.bbncbot.ocr.permission.BIND_OCR"
        android:protectionLevel="signature" />

    <!-- 主 APK 声明此权限才能 bindService -->
    <uses-permission android:name="com.bbncbot.ocr.permission.BIND_OCR" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MaterialComponents.DayNight"
        tools:targetApi="34">

        <!-- 启动页：仅展示"OCR 模块已安装"，无实际交互 -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            OCR 识别 Service
            - exported=true：允许主 APK（:app）跨进程绑定
            - permission=com.bbncbot.ocr.permission.BIND_OCR：signature 级权限保护
            - 主 APK 通过 action="com.bbncbot.ocr.action.RECOGNIZE" + package="com.bbncbot.ocr" 绑定
        -->
        <service
            android:name=".OcrService"
            android:exported="true"
            android:permission="com.bbncbot.ocr.permission.BIND_OCR">
            <intent-filter>
                <action android:name="com.bbncbot.ocr.action.RECOGNIZE" />
            </intent-filter>
        </service>

    </application>

</manifest>
